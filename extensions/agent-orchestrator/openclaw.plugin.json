{
  "id": "agent-orchestrator",
  "name": "Agent Orchestrator",
  "description": "Multi-agent task decomposition with role-based boundaries and inter-agent messaging",
  "version": "2026.3.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mail": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "logging": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "includeBodyPreview": {
                "type": "boolean"
              },
              "bodyPreviewChars": {
                "type": "integer"
              },
              "events": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "send": {
                    "type": "boolean"
                  },
                  "receipt": {
                    "type": "boolean"
                  },
                  "forward": {
                    "type": "boolean"
                  },
                  "ack": {
                    "type": "boolean"
                  },
                  "bounce": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "rules": {
            "type": "object"
          },
          "mailbox_acls": {
            "type": "object"
          },
          "delivery_policies": {
            "type": "object"
          }
        }
      },
      "orchestration": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "maxDepth": {
            "type": "number"
          },
          "maxConcurrentAgents": {
            "type": "number"
          },
          "watchdogIntervalMs": {
            "type": "number"
          },
          "staleThresholdMs": {
            "type": "number"
          },
          "agentRoles": {
            "type": "object",
            "description": "Maps agent IDs to orchestrator roles for auto-bootstrap.",
            "additionalProperties": {
              "type": "string",
              "enum": ["orchestrator", "lead", "scout", "builder", "reviewer"]
            }
          }
        }
      },
      "enforcement": {
        "type": "object",
        "description": "Enforcement policies for agent behavior (e.g. memory search before proceeding).",
        "additionalProperties": false,
        "properties": {
          "memorySearch": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Enable memory search enforcement. Default: false."
              },
              "policy": {
                "type": "string",
                "enum": ["reject", "nudge"],
                "description": "reject = block tool calls until memory_search is called; nudge = inject a reminder. Default: nudge."
              },
              "toolCallThreshold": {
                "type": "integer",
                "description": "Number of tool calls before enforcement triggers. 0 = disabled. Default: 0."
              },
              "roles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["orchestrator", "lead", "scout", "builder", "reviewer"]
                },
                "description": "Which roles to enforce. Omit for all roles."
              }
            }
          }
        }
      },
      "memoryFeedback": {
        "type": "object",
        "description": "Ephemeral end-of-session memory reflection config.",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "model": { "type": "string" },
          "autoWriteThreshold": { "type": "number" },
          "maxContextMessages": { "type": "integer" }
        }
      },
      "rules": {
        "type": "object"
      },
      "mailbox_acls": {
        "type": "object"
      },
      "delivery_policies": {
        "type": "object"
      }
    }
  }
}
